<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<title>Numberbox Component — fgta5js Documentation</title>
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">

	<!-- Library styles -->
	<link rel="stylesheet" href="styles/fgta5js-v1.9.2.min.css" />

	<!-- Core Demo stylesheet & Docs overrides -->
	<link rel="stylesheet" href="styles/demo.css" />
	<link rel="stylesheet" href="styles/documentation.css" />
</head>

<body>
	<!-- Register fgta5 global components namespace -->
	<script type="module" src="scripts/fgta5js-v1.9.2.min.js"></script>

	<div class="container">
		<!-- Back link -->
		<a href="/" class="back-link">
			<svg viewBox="0 0 24 24">
				<line x1="19" y1="12" x2="5" y2="12"></line>
				<polyline points="12 19 5 12 12 5"></polyline>
			</svg>
			Back to Overview
		</a>

		<!-- Header -->
		<header style="text-align: left; margin-bottom: 2.5rem;">
			<div class="badge">
				<span class="badge-dot"></span>
				Component
			</div>
			<h1 style="font-size: 2.75rem; margin-bottom: 0.5rem; display: block;">Numberbox</h1>
			<p class="hero-description" style="margin: 0; text-align: left; font-size: 1rem;">
				A specialized numeric entry field class that supports thousands separator formatting, custom decimal
				precision, constraints, and read-only mode state management.
			</p>
		</header>

		<!-- Main Documentation Layout -->
		<div class="doc-layout">
			<!-- Sidebar -->
			<aside class="doc-sidebar">
				<div class="doc-nav-card">
					<h4>Contents</h4>
					<ul class="doc-nav-list">
						<li class="doc-nav-item"><a href="#overview">Overview</a></li>
						<li class="doc-nav-item"><a href="#playground">Interactive Playground</a></li>
						<li class="doc-nav-item"><a href="#html-markup">HTML Markup</a></li>
						<li class="doc-nav-item"><a href="#properties">Properties</a></li>
						<li class="doc-nav-item"><a href="#methods">Methods</a></li>
						<li class="doc-nav-item"><a href="#attributes">HTML Attributes</a></li>
					</ul>
				</div>
			</aside>

			<!-- Content Area -->
			<main class="doc-content">
				<!-- Overview Section -->
				<section id="overview" class="doc-section">
					<h2>Overview</h2>
					<div class="doc-callout">
						<strong>Inheritance Notice:</strong> Class <code>Numberbox</code> inherits all of its core state
						tracking, validation logic, editing mode configurations, and event handlers from the abstract
						base class <a href="/input"><code>Input</code></a>.
					</div>
					<p>
						The <code>Numberbox</code> class handles formatted number entries within the
						<code>fgta5js</code> framework.
						It formats input numbers with comma group separators on blur while allowing raw numeric editing
						on focus.
						It handles value bounds (min/max), step values, custom floating-point precision, and read-only
						toggling.
					</p>
				</section>

				<!-- Interactive Playground Section -->
				<section id="playground" class="doc-section">
					<h2>Interactive Playground</h2>
					<p>Try interacting with the live component below and watch how the internal states change
						dynamically.</p>

					<div class="playground-card">
						<div class="playground-header">
							<span class="playground-title">Live Preview</span>
						</div>

						<div class="playground-body">
							<!-- Interactive Component instance -->
							<div class="playground-left">
								<div class="demo-input-field" field="playground_numberbox" style="flex: 1 1 100%;">
									<label for="playground_numberbox">Score / Score Amount</label>
									<input id="playground_numberbox" fgta5-component="Numberbox"
										placeholder="Enter a number..." autocomplete="off" precision="2" min="10"
										max="1000" required>
								</div>

								<div class="playground-controls">
									<button id="btn_toggle_edit">Toggle Edit State</button>
									<button id="btn_set_val">Set to 250.75</button>
									<button id="btn_focus">Focus Input</button>
									<button id="btn_reset_last">Commit / Commit Save</button>
								</div>
							</div>

							<!-- Dynamic property states monitor -->
							<div class="playground-right">
								<h5>Component State</h5>
								<div class="playground-stat">
									<span class="playground-stat-name">.value</span>
									<span class="playground-stat-value" id="state_value">0</span>
								</div>
								<div class="playground-stat">
									<span class="playground-stat-name">.InEditMode</span>
									<span class="playground-stat-value" id="state_editmode">true</span>
								</div>
								<div class="playground-stat">
									<span class="playground-stat-name">.getLastValue()</span>
									<span class="playground-stat-value" id="state_lastvalue">0</span>
								</div>
								<div class="playground-stat">
									<span class="playground-stat-name">.isChanged()</span>
									<span class="playground-stat-value" id="state_ischanged">false</span>
								</div>
							</div>
						</div>
					</div>
				</section>

				<!-- HTML Markup Section -->
				<section id="html-markup" class="doc-section">
					<h2>HTML Markup</h2>
					<p>Define numeric inputs in your markup. Set attributes like <code>precision</code>,
						<code>min</code>, and <code>max</code> to control behavior.
					</p>

					<pre><code><span class="hl-comment">&lt;!-- Numeric Input with 2 Decimal Digits --&gt;</span>
&lt;<span class="hl-tag">div</span> <span class="hl-attr">class</span>=<span class="hl-string">"demo-input-field"</span> <span class="hl-attr">field</span>=<span class="hl-string">"obj_score"</span>&gt;
  &lt;<span class="hl-tag">label</span> <span class="hl-attr">for</span>=<span class="hl-string">"obj_score"</span>&gt;Score&lt;/<span class="hl-tag">label</span>&gt;
  &lt;<span class="hl-tag">input</span> <span class="hl-attr">id</span>=<span class="hl-string">"obj_score"</span> <span class="hl-attr">fgta5-component</span>=<span class="hl-string">"Numberbox"</span> <span class="hl-attr">precision</span>=<span class="hl-string">"2"</span> <span class="hl-attr">min</span>=<span class="hl-string">"0"</span> <span class="hl-attr">max</span>=<span class="hl-string">"100"</span> <span class="hl-attr">required</span>&gt;
&lt;/<span class="hl-tag">div</span>&gt;</code></pre>
				</section>

				<!-- Properties Section -->
				<section id="properties" class="doc-section">
					<h2>Properties</h2>
					<div class="api-table-wrapper">
						<table class="api-table">
							<thead>
								<tr>
									<th>Property</th>
									<th>Type</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td><code>value</code></td>
									<td><code>Number</code></td>
									<td>Get or set the current numeric value. Always returns a JavaScript number
										representation.</td>
								</tr>
								<tr>
									<td><code>InEditMode</code></td>
									<td><code>Boolean</code></td>
									<td>Gets the current edit/readonly state of the component (Read-only). Set using
										<code>setEditingMode()</code>.
									</td>
								</tr>
								<tr>
									<td><code>disabled</code></td>
									<td><code>Boolean</code></td>
									<td>Gets or sets the component disabled state. Blocks input if true.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</section>

				<!-- Methods Section -->
				<section id="methods" class="doc-section">
					<h2>Methods</h2>
					<div class="api-table-wrapper">
						<table class="api-table">
							<thead>
								<tr>
									<th>Method</th>
									<th>Arguments</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td><code>constructor(id)</code></td>
									<td><code>(id: String)</code></td>
									<td>Creates and binds a new <code>Numberbox</code> instance to the HTML element
										using the specified ID.</td>
								</tr>
								<tr>
									<td><code>setEditingMode(ineditmode)</code></td>
									<td><code>(ineditmode: Boolean)</code></td>
									<td>Toggles editing mode. Setting to <code>false</code> locks input, sets readonly,
										and clears errors.</td>
								</tr>
								<tr>
									<td><code>suspend(doSuspend, keepState)</code></td>
									<td><code>(doSuspend: Boolean, keepState: Boolean)</code></td>
									<td>Suspends the component behavior and locks/disables input elements depending on
										arguments.</td>
								</tr>
								<tr>
									<td><code>isSuspended()</code></td>
									<td><code>()</code></td>
									<td>Returns true if the component is currently suspended.</td>
								</tr>
								<tr>
									<td><code>newData(initialvalue)</code></td>
									<td><code>(initialvalue: Number)</code></td>
									<td>Resets value and sets new baseline value (defaults to <code>0</code> if not
										provided).</td>
								</tr>
								<tr>
									<td><code>getLastValue()</code></td>
									<td><code>()</code></td>
									<td>Returns the last saved number value.</td>
								</tr>
								<tr>
									<td><code>isChanged()</code></td>
									<td><code>()</code></td>
									<td>Checks if the current <code>value</code> differs from the last saved state
										value.</td>
								</tr>
								<tr>
									<td><code>focus()</code></td>
									<td><code>()</code></td>
									<td>Programmatically shifts focus onto the numeric display field.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</section>

				<!-- HTML Attributes Section -->
				<section id="attributes" class="doc-section">
					<h2>HTML Attributes</h2>
					<div class="api-table-wrapper">
						<table class="api-table">
							<thead>
								<tr>
									<th>Attribute</th>
									<th>Values</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td><code>precision</code></td>
									<td><code>Number</code></td>
									<td>Specifies the number of decimal digits displayed and saved (e.g. <code>2</code>
										for currency).</td>
								</tr>
								<tr>
									<td><code>digitgrouping</code></td>
									<td><code>"true" | "false"</code></td>
									<td>Specifies whether thousands separators (commas) should be formatted. Default is
										<code>"true"</code>.
									</td>
								</tr>
								<tr>
									<td><code>min</code></td>
									<td><code>Number</code></td>
									<td>Minimum numeric boundary value enforced during validation on blur.</td>
								</tr>
								<tr>
									<td><code>max</code></td>
									<td><code>Number</code></td>
									<td>Maximum numeric boundary value enforced during validation on blur.</td>
								</tr>
								<tr>
									<td><code>required</code></td>
									<td>N/A</td>
									<td>Marks the field as required.</td>
								</tr>
								<tr>
									<td><code>data-tabindex</code></td>
									<td><code>Number</code></td>
									<td>Sets the native tabindex on the final display element.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</section>
			</main>
		</div>

		<!-- Footer -->
		<footer>
			<p class="footer-text">© 2026 fgta5js. Built with a core focus on performance and simplicity.</p>
		</footer>
	</div>

	<!-- Interactive page scripting -->
	<script type="module">
		window.addEventListener("load", async () => {
			// Initialize component
			const nmb = new $fgta5.Numberbox('playground_numberbox');
			window.nmb = nmb; // Allow console debugging

			// UI state update elements
			const stateValue = document.getElementById('state_value');
			const stateEditMode = document.getElementById('state_editmode');
			const stateLastValue = document.getElementById('state_lastvalue');
			const stateIsChanged = document.getElementById('state_ischanged');

			// Sync status displays
			const updateStats = () => {
				stateValue.innerText = nmb.value;
				stateEditMode.innerText = nmb.InEditMode ? "true" : "false";
				stateLastValue.innerText = nmb.getLastValue();
				stateIsChanged.innerText = nmb.isChanged() ? "true" : "false";
			};

			// Listen for events (Numberbox dispatches custom event 'changed')
			nmb.Listener.addEventListener('changed', updateStats);
			nmb.Nodes.Display.addEventListener('input', updateStats);
			nmb.Nodes.Display.addEventListener('blur', updateStats);

			// Setup button control listeners
			document.getElementById('btn_toggle_edit').addEventListener('click', () => {
				nmb.setEditingMode(!nmb.InEditMode);
				updateStats();
			});

			document.getElementById('btn_set_val').addEventListener('click', () => {
				if (nmb.InEditMode) {
					nmb.value = 250.75;
					updateStats();
				}
			});

			document.getElementById('btn_focus').addEventListener('click', () => {
				nmb.focus();
			});

			document.getElementById('btn_reset_last').addEventListener('click', () => {
				nmb._setLastValue(nmb.value);
				updateStats();
			});

			// Initial Sync
			updateStats();
		});
	</script>
</body>

</html>