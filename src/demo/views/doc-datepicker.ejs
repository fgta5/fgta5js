<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<title>Datepicker Component - fgta5js Documentation</title>
	<link rel="icon" href="/favicon.ico" type="image/x-icon" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">


	<!-- Library styles: Production -->
	<link rel="stylesheet" href="demo/styles/fgta5js-v1.9.2.min.css" />


	<!-- Core Demo stylesheet & Docs overrides -->
	<link rel="stylesheet" href="demo/styles/demo.css" />
	<link rel="stylesheet" href="demo/styles/ferrine.css" />
	<link rel="stylesheet" href="demo/styles/documentation.css" />


	<script>
		window.$validators = {}
	</script>
</head>

<body>
	<!-- Register fgta5 global components namespace -->
	<script type="module" src="demo/scripts/fgta5js-v1.9.2.min.js"></script>


	<div class="container">
		<!-- Back link -->
		<div style="display: flex; justify-content: space-between;">
			<%-include('_backlink.ejs') %>
		</div>

		<!-- Header -->
		<header style="text-align: left; margin-bottom: 2.5rem;">
			<div class="badge">
				<span class="badge-dot"></span>
				Component
			</div>


			<div style="display: flex; column-gap: 1rem;">
				<div class="title-icon-wrapper">
					<svg viewBox="0 0 24 24">
						<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
						<line x1="16" y1="2" x2="16" y2="6"></line>
						<line x1="8" y1="2" x2="8" y2="6"></line>
						<line x1="3" y1="10" x2="21" y2="10"></line>
					</svg>
				</div>

				<h1 style="font-size: 2.75rem; margin-bottom: 0.5rem; display: block;">Datepicker</h1>
			</div>




			<p class="hero-description" style="margin: 0; text-align: left; font-size: 1rem;">
				A specialized calendar input class that provides standardized date selection, custom range
				constraints
				(min/max),
				localized formatting display, and edit/read-only mode state management.
			</p>
		</header>

		<!-- Main Documentation Layout -->
		<div class="doc-layout">
			<!-- Sidebar -->
			<aside class="doc-sidebar">
				<div class="doc-nav-card">
					<h4>Contents</h4>
					<ul class="doc-nav-list">
						<li class="doc-nav-item"><a href="#overview">Overview</a></li>
						<li class="doc-nav-item"><a href="#playground">Interactive Playground</a></li>
						<li class="doc-nav-item"><a href="#html-markup">HTML Markup</a></li>
						<li class="doc-nav-item"><a href="#attributes">HTML Attributes</a></li>
						<li class="doc-nav-item"><a href="#properties">Properties</a></li>
						<li class="doc-nav-item"><a href="#methods">Methods</a></li>
					</ul>
				</div>
				<%-include('_mnu-components.ejs')%>
			</aside>

			<!-- Content Area -->
			<main class="doc-content">
				<!-- Overview Section -->
				<section id="overview" class="doc-section">
					<h2>Overview</h2>
					<div class="doc-callout">
						<strong>Inheritance Notice:</strong> Class <code>Datepicker</code> inherits all of its core
						state
						tracking, validation logic, editing mode configurations, and event handlers from the
						abstract
						base class <a href="/input"><code>Input</code></a>.
					</div>
					<p>
						The <code>Datepicker</code> class integrates custom input calendars within the
						<code>fgta5js</code> framework.
						It formats selected dates into readable localized format strings (e.g.,
						<code>DD MMM YYYY</code>) on blur/display
						while submitting raw ISO dates (<code>YYYY-MM-DD</code>) programmatically.
					</p>
				</section>

				<!-- Interactive Playground Section -->
				<section id="playground" class="doc-section">
					<h2>Interactive Playground</h2>
					<p>Try interacting with the live component below and watch how the internal states change
						dynamically.</p>

					<div class="playground-card">
						<div class="playground-header">
							<span class="playground-title">Live Preview</span>
						</div>

						<div class="playground-body">
							<!-- Interactive Component instance -->
							<div class="playground-left">


								<div class="demo-input-field" field="playground_datepicker" style="flex: 1 1 100%;">
									<form id="myform" locked="true">
										<label for="playground_datepicker">Transaction Date</label>
										<input id="playground_datepicker" fgta5-component="Datepicker"
											placeholder="Select a date..." autocomplete="off" required min="2020-01-01"
											max="2030-12-31">
									</form>
								</div>


								<div class="playground-controls">
									<button id="btn_toggle_edit" class="demo-button">Toggle Edit State</button>
									<button id="btn_set_val" class="demo-button">Set to "2026-05-31"</button>
									<button id="btn_focus" class="demo-button">Focus Input</button>
									<button id="btn_commit" class="demo-button">Commit / Save</button>
									<button id="btn_reset" class="demo-button">Reset</button>
								</div>
							</div>

							<!-- Dynamic property states monitor -->
							<div class="playground-right">
								<h5>Component State</h5>
								<div class="playground-stat">
									<span class="playground-stat-name">.value</span>
									<span class="playground-stat-value" id="state_value">""</span>
								</div>
								<div class="playground-stat">
									<span class="playground-stat-name">.InEditMode</span>
									<span class="playground-stat-value" id="state_editmode">true</span>
								</div>
								<div class="playground-stat">
									<span class="playground-stat-name">.getLastValue()</span>
									<span class="playground-stat-value" id="state_lastvalue">""</span>
								</div>
								<div class="playground-stat">
									<span class="playground-stat-name">.isChanged()</span>
									<span class="playground-stat-value" id="state_ischanged">false</span>
								</div>
							</div>
						</div>
					</div>
				</section>

				<!-- HTML Markup Section -->
				<section id="html-markup" class="doc-section">
					<h2>HTML Markup</h2>
					<p>Define date inputs using standard HTML. Use <code>fgta5-component="Datepicker"</code> to
						enable
						binding.
					</p>

					<pre><code>&lt;<span class="hl-tag">form</span> <span class="hl-attr">id</span>=<span class="hl-string">"myform"</span> <span class="hl-attr">locked</span>=<span class="hl-string">"true"</span>&gt;
  <span class="hl-comment">&lt;!-- Datepicker Input --&gt;</span>
  &lt;<span class="hl-tag">div</span> <span class="hl-attr">class</span>=<span class="hl-string">"demo-input-field"</span> <span class="hl-attr">field</span>=<span class="hl-string">"obj_date"</span>&gt;
    &lt;<span class="hl-tag">label</span> <span class="hl-attr">for</span>=<span class="hl-string">"obj_date"</span>&gt;Transaction Date&lt;/<span class="hl-tag">label</span>&gt;
    &lt;<span class="hl-tag">input</span> <span class="hl-attr">id</span>=<span class="hl-string">"obj_date"</span> <span class="hl-attr">fgta5-component</span>=<span class="hl-string">"Datepicker"</span> <span class="hl-attr">placeholder</span>=<span class="hl-string">"Select date"</span> <span class="hl-attr">required</span>&gt;
  &lt;/<span class="hl-tag">div</span>&gt;
&lt;/<span class="hl-tag">form</span>&gt;</code></pre>

					<p>Initialize and render the form in JavaScript:</p>
					<pre><code><span class="hl-keyword">const</span> form = <span class="hl-keyword">new</span> <span class="hl-class">$fgta5.Form</span>(<span class="hl-string">'myform'</span>);
form.<span class="hl-function">render</span>()</code></pre>
				</section>

				<!-- HTML Attributes Section -->
				<section id="attributes" class="doc-section">
					<h2>HTML Attributes</h2>
					<div class="api-table-wrapper">
						<table class="api-table">
							<thead>
								<tr>
									<th>Attribute</th>
									<th>Values</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td><code>placeholder</code></td>
									<td><code>String</code></td>
									<td>Helpful placeholder text displayed when the input is empty.</td>
								</tr>
								<tr>
									<td><code>disabled</code></td>
									<td>N/A</td>
									<td>Disables the picker tanggal, preventing any interaction.</td>
								</tr>
								<tr>
									<td><code>required</code></td>
									<td>N/A</td>
									<td>Marks the component as required during form validation.</td>
								</tr>
								<tr>
									<td><code>min</code></td>
									<td><code>String (YYYY-MM-DD)</code></td>
									<td>Lower date boundary validation constraint.</td>
								</tr>
								<tr>
									<td><code>max</code></td>
									<td><code>String (YYYY-MM-DD)</code></td>
									<td>Upper date boundary validation constraint.</td>
								</tr>
								<tr>
									<td><code>data-tabindex</code></td>
									<td><code>Number</code></td>
									<td>Sets the native tabindex on the final display element for keyboard navigation.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</section>

				<!-- Properties Section -->
				<section id="properties" class="doc-section">
					<h2>Properties</h2>
					<div class="api-table-wrapper">
						<table class="api-table">
							<thead>
								<tr>
									<th>Property</th>
									<th>Type</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td><code>value</code></td>
									<td><code>String</code></td>
									<td>Get or set the current date value. Returns an ISO date string format
										(<code>YYYY-MM-DD</code>).
									</td>
								</tr>
								<tr>
									<td><code>min</code></td>
									<td><code>Date | String</code></td>
									<td>Get or set the minimum date limit boundary.
									</td>
								</tr>
								<tr>
									<td><code>max</code></td>
									<td><code>Date | String</code></td>
									<td>Get or set the maximum date limit boundary.
									</td>
								</tr>
								<tr>
									<td><code>InEditMode</code></td>
									<td><code>Boolean</code></td>
									<td>Gets the current edit/readonly state of the component (Read-only). To
										modify,
										use <code>setEditingMode()</code>.</td>
								</tr>
								<tr>
									<td><code>disabled</code></td>
									<td><code>Boolean</code></td>
									<td>Gets or sets the component disabled state.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</section>

				<!-- Methods Section -->
				<section id="methods" class="doc-section">
					<h2>Methods</h2>
					<div class="api-table-wrapper">
						<table class="api-table">
							<thead>
								<tr>
									<th>Method</th>
									<th>Arguments</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td><code>constructor(id)</code></td>
									<td><code>(id: String)</code></td>
									<td>Creates and binds a new <code>Datepicker</code> instance to the HTML element
										using
										the specified ID.</td>
								</tr>
								<tr>
									<td><code>setEditingMode(ineditmode)</code></td>
									<td><code>(ineditmode: Boolean)</code></td>
									<td>Toggles editing mode. Setting to <code>false</code> locks the component as
										read-only and clears errors.</td>
								</tr>
								<tr>
									<td><code>suspend(doSuspend, keepState)</code></td>
									<td><code>(doSuspend: Boolean, keepState: Boolean)</code></td>
									<td>Suspends input interaction.</td>
								</tr>
								<tr>
									<td><code>isSuspended()</code></td>
									<td><code>()</code></td>
									<td>Checks if the component is suspended.</td>
								</tr>
								<tr>
									<td><code>newData(initialvalue)</code></td>
									<td><code>(initialvalue: String)</code></td>
									<td>Initializes the input with a new value and resets change detection states.
									</td>
								</tr>
								<tr>
									<td><code>getLastValue()</code></td>
									<td><code>()</code></td>
									<td>Returns the last committed/saved value string.</td>
								</tr>
								<tr>
									<td><code>isChanged()</code></td>
									<td><code>()</code></td>
									<td>Checks if the current <code>value</code> differs from the last saved state
										value.</td>
								</tr>
								<tr>
									<td><code>focus()</code></td>
									<td><code>()</code></td>
									<td>Programmatically shifts focus onto the date field element.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</section>

			</main>
		</div>

		<!-- Footer -->
		<%-include('_footer.ejs')%>
	</div>

	<!-- Interactive page scripting -->
	<script type="module">
		window.addEventListener("load", async () => {
			// Initialize component
			const form = new $fgta5.Form('myform');
			const dtp = form.Inputs.playground_datepicker

			form.render()

			// UI state update elements
			const stateValue = document.getElementById('state_value');
			const stateEditMode = document.getElementById('state_editmode');
			const stateLastValue = document.getElementById('state_lastvalue');
			const stateIsChanged = document.getElementById('state_ischanged');

			// Sync status displays
			const updateStats = () => {
				stateValue.innerText = JSON.stringify(dtp.value);
				stateEditMode.innerText = dtp.InEditMode ? "true" : "false";
				stateLastValue.innerText = JSON.stringify(dtp.getLastValue());
				stateIsChanged.innerText = dtp.isChanged() ? "true" : "false";
			};

			// Listen for events
			dtp.Listener.addEventListener('changed', updateStats);
			dtp.Nodes.Display.addEventListener('input', updateStats);
			dtp.Nodes.Display.addEventListener('blur', updateStats);

			// Setup button control listeners
			document.getElementById('btn_toggle_edit').addEventListener('click', () => {
				form.lock(dtp.InEditMode)
				updateStats();
			});

			document.getElementById('btn_set_val').addEventListener('click', () => {
				if (dtp.InEditMode) {
					dtp.value = "2026-05-31";
					updateStats();
				}
			});

			document.getElementById('btn_focus').addEventListener('click', () => {
				dtp.focus();
			});

			document.getElementById('btn_commit').addEventListener('click', () => {
				form.acceptChanges()
				updateStats();
			});

			document.getElementById('btn_reset').addEventListener('click', () => {
				form.reset()
				updateStats();
			});

			// Initial Sync
			updateStats();
		});
	</script>
</body>

</html>