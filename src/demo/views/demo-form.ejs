<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<title>Form Demo — fgta5js</title>
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">

	<!-- Library styles (direct loading) -->
	<link rel="stylesheet" href="demo/styles/fgta5js-v1.9.2.min.css" />

	<!-- Core Demo stylesheet -->
	<link rel="stylesheet" href="demo/styles/demo.css" />
	<link rel="stylesheet" href="demo/styles/ferrine.css" />
</head>

<body>
	<!-- Entry script for the library -->
	<script type="module" src="demo/scripts/fgta5js-v1.9.2.min.js"></script>

	<div class="container">
		<!-- Back to Overview link -->
		<div style="display: flex; justify-content: space-between;">
			<%-include('_backlink.ejs') %>
		</div>

		<!-- Title Section -->
		<header style="text-align: left; margin-bottom: 2.5rem;">
			<h1 style="font-size: 2.75rem; margin-bottom: 0.5rem;">Form Demo</h1>
			<p class="hero-description" style="margin: 0; text-align: left; font-size: 1rem;">
				Test input components, event triggers, validations, and state locking behaviors in real-time.
			</p>
		</header>

		<main>
			<!-- Action Buttons / Control Panel -->
			<section class="control-panel action-control-panel">
				<div class="control-group">
					<button id="btn_edittogle" class="demo-button" style="background-color: rgb(255 191 12);">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
							stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
							<path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
						</svg>
						Toggle Edit/Lock
					</button>
					<span class="state-badge" id="txtState">Locked</span>
				</div>

				<div class="control-group" style="margin-left: auto;">
					<button id="btn_reset" class="demo-button">Reset</button>
					<button id="btn_new" class="demo-button">New Form</button>
					<button id="btn_save" class="demo-button">Save Changes</button>
				</div>
			</section>

			<!-- Helper Tools -->
			<section class="control-panel"
				style="padding: 0.875rem 1.25rem; background-color: #f8fafc; border-style: dashed; margin-bottom: 2rem;">
				<span
					style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.05em; margin-right: 0.5rem;">Debug
					Tools:</span>
				<div class="control-group">
					<button id="btn_testvalidation" style="font-size: 0.75rem; padding: 0.375rem 0.75rem;"
						class="demo-button">Validate
						Form</button>
					<button id="btn_testdised" style="font-size: 0.75rem; padding: 0.375rem 0.75rem;"
						class="demo-button">Toggle Disable
						State</button>
					<button id="btn_clearerror" style="font-size: 0.75rem; padding: 0.375rem 0.75rem;"
						class="demo-button">Clear Field
						Errors</button>
				</div>
			</section>

			<!-- Main Form Card -->
			<section class="form-card">
				<!-- Search Filter Area (styled cleanly inside form card top) -->
				<div class="search-section">
					<div class="search-field">
						<label for="obj_searchcity">Filter by City</label>
						<input class="searchcomp" id="obj_searchcity" fgta5-component="Combobox"
							placeholder="Select City..." autocomplete="off" spellcheck="false" required>
						<datalist for="obj_searchcity">
							<option value="JKT">Jakarta</option>
							<option value="MGL">Magelang</option>
							<option value="JGJ">Jogjakarta</option>
							<option value="SLG">Salatiga</option>
							<option value="SLO">Solo</option>
						</datalist>
					</div>

					<div class="search-field">
						<label for="obj_searchtext">Filter by Text</label>
						<input class="searchcomp" id="obj_searchtext" fgta5-component="Textbox"
							placeholder="Type here..." autocomplete="off" spellcheck="false">
					</div>

					<div class="search-field">
						<label for="obj_searchdate">Filter by Date</label>
						<input class="searchcomp" id="obj_searchdate" fgta5-component="Datepicker"
							placeholder="Select Date..." autocomplete="off" spellcheck="false">
					</div>
				</div>

				<!-- Form Inputs Grid -->
				<form id="myform" locked="true">
					<div class="form-grid">
						<!-- Nama Input -->
						<div class="demo-input-field" field="obj_nama">
							<label for="obj_nama">Name</label>
							<input id="obj_nama" fgta5-component="Textbox" placeholder="Enter your name"
								autocomplete="off" spellcheck="false" value="Ferrine" character-case="uppercase"
								required minlength="3" maxlength="15" binding="nama"
								description="Please enter your name (3 - 15 characters)"
								invalid-message="Name must be filled, 3 to 15 characters"
								invalid-message-required="Name is required"
								invalid-message-minlength="Name must be at least 3 characters"
								invalid-message-maxlength="Name cannot exceed 15 characters">
						</div>

						<!-- Disabled checkbox (styled inline nicely) -->
						<div class="demo-input-field" field="obj_disabled"
							style="justify-content: center; align-items: flex-start;">
							<label for="obj_disabled">Account Is Disabled</label>
							<input id="obj_disabled" fgta5-component="Checkbox" type="checkbox" binding="isdisabled">

						</div>

						<!-- Alamat Input -->
						<div class="demo-input-field" field="obj_alamat">
							<label for="obj_alamat">Address</label>
							<input id="obj_alamat" fgta5-component="Textbox" placeholder="Enter your full address"
								autocomplete="off" spellcheck="false" required minlength="3" maxlength="90"
								binding="alamat" invalid-message="Address must be filled (3 to 90 characters)">
						</div>

						<!-- Nilai Input -->
						<div class="demo-input-field" field="obj_nilai">
							<div style="max-width: 300px;">
								<label for="obj_nilai">Score / Amount</label>
								<input id="obj_nilai" fgta5-component="Numberbox" placeholder="Enter value"
									autocomplete="off" spellcheck="false" min="50" max="200" maxlength="6" decimal="2"
									binding="nilai" value="100" description="Enter numeric value between 50 and 200"
									invalid-message="Value must be in range 50 to 200">
							</div>
						</div>

						<!-- Tanggal Input -->
						<div class="demo-input-field" field="obj_tanggal">
							<label for="obj_tanggal">Date</label>
							<input id="obj_tanggal" fgta5-component="Datepicker" placeholder="Select Date..."
								autocomplete="off" spellcheck="false" required min="2025-06-02" binding="tanggal"
								description="Choose a date">
						</div>

						<!-- Jam Input -->
						<div class="demo-input-field" field="obj_jam">
							<label for="obj_jam">Time</label>
							<input id="obj_jam" fgta5-component="Timepicker" placeholder="Select Time..."
								autocomplete="off" spellcheck="false" required binding="jam"
								description="Select hours & minutes">
						</div>

						<!-- Kota Input -->
						<div class="demo-input-field" field="obj_kota">
							<label for="obj_kota">City</label>
							<input id="obj_kota" fgta5-component="Combobox" placeholder="Search and select city..."
								autocomplete="off" spellcheck="false" binding="kota" description="City of residence"
								invalid-message="City is required">
						</div>

						<!-- File Input -->
						<div class="demo-input-field" field="obj_file">
							<label for="obj_file">Attachment File</label>
							<input id="obj_file" fgta5-component="Filebox" required placeholder="Upload file"
								binding="file">
						</div>
					</div>
				</form>
			</section>


			<section class="design-tips-card">
				<div class="tips-icon-wrapper">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path
							d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.91A1.996 1.996 0 0 1 14 18h-4a1.996 1.996 0 0 1-1.072-1.457l-.548-.91z" />
					</svg>
				</div>
				<div class="tips-content">
					<h3>Design Tips: Design for Visual Anchors, Avoid Monotony</h3>
					<p>
						While perfectly uniform rows and columns may create a clean and aesthetically pleasing layout,
						they
						often lead to visual monotony that causes eye fatigue and slows down high-speed data entry.
						Users who
						handle repetitive tasks rely heavily on spatial memory and visual anchors—recognizing fields by
						their
						distinct shapes and positions rather than reading labels. Designing uniform sizes forces users
						to scan
						text repeatedly and increases the need for tedious vertical scrolling; instead, vary column and
						field
						widths based on their data function to create distinct visual cues that support faster, less
						tiring
						navigation.
					</p>
				</div>
			</section>
		</main>

		<!-- Footer -->
		<%-include('_footer.ejs')%>
	</div>

	<!-- Page Loader Mask -->
	<div id="fgta5-loading-pagemask">
		<div>Please Wait...</div>
	</div>

	<!-- Loader & Binding Modules -->
	<script type="module">
		import Page from '/demo/scripts/demo-form.mjs'

		window.addEventListener("load", async (event) => {
			var $page = new Page();
			await $page.main();

			var pagemask = document.getElementById('fgta5-loading-pagemask')
			if (pagemask) {
				pagemask.style.opacity = 0
				pagemask.style.visibility = 'hidden'
				setTimeout(() => {
					if (pagemask.parentNode) {
						pagemask.parentNode.removeChild(pagemask)
					}
				}, 500);
			}
		});
	</script>
</body>

</html>