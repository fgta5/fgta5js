<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<title>Filebox Component — fgta5js Documentation</title>
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">


	<!-- Library styles: Production -->
	<link rel="stylesheet" href="styles/fgta5js-v1.9.2.min.css" />


	<!-- Core Demo stylesheet & Docs overrides -->
	<link rel="stylesheet" href="styles/demo.css" />
	<link rel="stylesheet" href="styles/ferrine.css" />
	<link rel="stylesheet" href="styles/documentation.css" />


	<script>
		window.$validators = {}
	</script>
</head>

<body>
	<!-- Register fgta5 global components namespace -->
	<script type="module" src="scripts/fgta5js-v1.9.2.min.js"></script>


	<div class="container">
		<!-- Back link -->
		<div style="display: flex; justify-content: space-between;">
			<%-include('_backlink.ejs') %>
		</div>

		<!-- Header -->
		<header style="text-align: left; margin-bottom: 2.5rem;">
			<div class="badge">
				<span class="badge-dot"></span>
				Component
			</div>


			<div style="display: flex; column-gap: 1rem;">
				<div class="title-icon-wrapper">
					<svg viewBox="0 0 24 24">
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
						<polyline points="17 8 12 3 7 8"></polyline>
						<line x1="12" y1="3" x2="12" y2="15"></line>
					</svg>
				</div>

				<h1 style="font-size: 2.75rem; margin-bottom: 0.5rem; display: block;">Filebox</h1>
			</div>




			<p class="hero-description" style="margin: 0; text-align: left; font-size: 1rem;">
				A specialized file upload input component featuring filename previews, download links integration, and edit/read-only mode state management.
			</p>
		</header>

		<!-- Main Documentation Layout -->
		<div class="doc-layout">
			<!-- Sidebar -->
			<aside class="doc-sidebar">
				<div class="doc-nav-card">
					<h4>Contents</h4>
					<ul class="doc-nav-list">
						<li class="doc-nav-item"><a href="#overview">Overview</a></li>
						<li class="doc-nav-item"><a href="#playground">Interactive Playground</a></li>
						<li class="doc-nav-item"><a href="#html-markup">HTML Markup</a></li>
						<li class="doc-nav-item"><a href="#properties">Properties</a></li>
						<li class="doc-nav-item"><a href="#methods">Methods</a></li>
						<li class="doc-nav-item"><a href="#attributes">HTML Attributes</a></li>
					</ul>
				</div>
				<%-include('_mnu-components.ejs')%>
			</aside>

			<!-- Content Area -->
			<main class="doc-content">
				<!-- Overview Section -->
				<section id="overview" class="doc-section">
					<h2>Overview</h2>
					<div class="doc-callout">
						<strong>Inheritance Notice:</strong> Class <code>Filebox</code> (also referenced as File Upload) inherits all of its core
						state tracking, validation logic, editing mode configurations, and event handlers from the
						abstract base class <a href="/input"><code>Input</code></a>.
					</div>
					<p>
						The <code>Filebox</code> class wraps HTML standard file inputs within the <code>fgta5js</code> framework. It formats selected file naming displays, supports optional download anchor nodes, and enables validation tracking for mandatory files.
					</p>
				</section>

				<!-- Interactive Playground Section -->
				<section id="playground" class="doc-section">
					<h2>Interactive Playground</h2>
					<p>Try interacting with the live component below and watch how the internal states change
						dynamically.</p>

					<div class="playground-card">
						<div class="playground-header">
							<span class="playground-title">Live Preview</span>
						</div>

						<div class="playground-body">
							<!-- Interactive Component instance -->
							<div class="playground-left">


								<div class="demo-input-field" field="playground_filebox" style="flex: 1 1 100%;">
									<form id="myform" locked="true">
										<label for="playground_filebox">Attachment Document</label>
										<input id="playground_filebox" fgta5-component="Filebox" required placeholder="Upload attachment file...">
									</form>
								</div>


								<div class="playground-controls">
									<button id="btn_toggle_edit" class="demo-button">Toggle Edit State</button>
									<button id="btn_set_link" class="demo-button">Set Download Link</button>
									<button id="btn_commit" class="demo-button">Commit / Save</button>
									<button id="btn_reset" class="demo-button">Reset</button>
								</div>
							</div>

							<!-- Dynamic property states monitor -->
							<div class="playground-right">
								<h5>Component State</h5>
								<div class="playground-stat">
									<span class="playground-stat-name">.value</span>
									<span class="playground-stat-value" id="state_value">""</span>
								</div>
								<div class="playground-stat">
									<span class="playground-stat-name">.file</span>
									<span class="playground-stat-value" id="state_file">0</span>
								</div>
								<div class="playground-stat">
									<span class="playground-stat-name">.InEditMode</span>
									<span class="playground-stat-value" id="state_editmode">true</span>
								</div>
								<div class="playground-stat">
									<span class="playground-stat-name">.getLastValue()</span>
									<span class="playground-stat-value" id="state_lastvalue">""</span>
								</div>
								<div class="playground-stat">
									<span class="playground-stat-name">.isChanged()</span>
									<span class="playground-stat-value" id="state_ischanged">false</span>
								</div>
							</div>
						</div>
					</div>
				</section>

				<!-- HTML Markup Section -->
				<section id="html-markup" class="doc-section">
					<h2>HTML Markup</h2>
					<p>Define standard file inputs using standard HTML. Set <code>fgta5-component="Filebox"</code> to enable binding.
					</p>

					<pre><code>&lt;<span class="hl-tag">form</span> <span class="hl-attr">id</span>=<span class="hl-string">"myform"</span> <span class="hl-attr">locked</span>=<span class="hl-string">"true"</span>&gt;
  <span class="hl-comment">&lt;!-- Filebox Input --&gt;</span>
  &lt;<span class="hl-tag">div</span> <span class="hl-attr">class</span>=<span class="hl-string">"demo-input-field"</span> <span class="hl-attr">field</span>=<span class="hl-string">"obj_file"</span>&gt;
    &lt;<span class="hl-tag">label</span> <span class="hl-attr">for</span>=<span class="hl-string">"obj_file"</span>&gt;Attachment File&lt;/<span class="hl-tag">label</span>&gt;
    &lt;<span class="hl-tag">input</span> <span class="hl-attr">id</span>=<span class="hl-string">"obj_file"</span> <span class="hl-attr">fgta5-component</span>=<span class="hl-string">"Filebox"</span> <span class="hl-attr">placeholder</span>=<span class="hl-string">"Upload file"</span> <span class="hl-attr">required</span>&gt;
  &lt;/<span class="hl-tag">div</span>&gt;
&lt;/<span class="hl-tag">form</span>&gt;</code></pre>

					<p>Initialize and render the form in JavaScript:</p>
					<pre><code><span class="hl-keyword">const</span> form = <span class="hl-keyword">new</span> <span class="hl-class">$fgta5.Form</span>(<span class="hl-string">'myform'</span>);
form.<span class="hl-function">render</span>()</code></pre>
				</section>

				<!-- Properties Section -->
				<section id="properties" class="doc-section">
					<h2>Properties</h2>
					<div class="api-table-wrapper">
						<table class="api-table">
							<thead>
								<tr>
									<th>Property</th>
									<th>Type</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td><code>value</code></td>
									<td><code>String</code></td>
									<td>Get or set the active filename text description.</td>
								</tr>
								<tr>
									<td><code>file</code></td>
									<td><code>File | Number</code></td>
									<td>Gets the raw selected browser <code>File</code> instance or <code>0</code> if none selected.</td>
								</tr>
								<tr>
									<td><code>InEditMode</code></td>
									<td><code>Boolean</code></td>
									<td>Gets the current edit/readonly state of the component (Read-only). To modify, use <code>setEditingMode()</code>.</td>
								</tr>
								<tr>
									<td><code>disabled</code></td>
									<td><code>Boolean</code></td>
									<td>Gets or sets the component disabled state.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</section>

				<!-- Methods Section -->
				<section id="methods" class="doc-section">
					<h2>Methods</h2>
					<div class="api-table-wrapper">
						<table class="api-table">
							<thead>
								<tr>
									<th>Method</th>
									<th>Arguments</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td><code>constructor(id)</code></td>
									<td><code>(id: String)</code></td>
									<td>Creates and binds a new <code>Filebox</code> instance to the HTML element using the specified ID.</td>
								</tr>
								<tr>
									<td><code>setEditingMode(ineditmode)</code></td>
									<td><code>(ineditmode: Boolean)</code></td>
									<td>Toggles editing mode. Setting to <code>false</code> locks the component as read-only, disabling interactive file selectors and clearing errors.</td>
								</tr>
								<tr>
									<td><code>suspend(doSuspend, keepState)</code></td>
									<td><code>(doSuspend: Boolean, keepState: Boolean)</code></td>
									<td>Suspends or reactivates input interaction.</td>
								</tr>
								<tr>
									<td><code>isSuspended()</code></td>
									<td><code>()</code></td>
									<td>Checks if the component is suspended.</td>
								</tr>
								<tr>
									<td><code>newData()</code></td>
									<td><code>()</code></td>
									<td>Clears the selected file list and resets display properties.</td>
								</tr>
								<tr>
									<td><code>setDownloadLink(linktext, url)</code></td>
									<td><code>(linktext: String, url: String | Function)</code></td>
									<td>Enables rendering an anchor tag with a download link or custom click callback underneath the input fields. Pass `null` to hide the download link.</td>
								</tr>
								<tr>
									<td><code>getLastValue()</code></td>
									<td><code>()</code></td>
									<td>Returns the last committed/saved filename string value.</td>
								</tr>
								<tr>
									<td><code>isChanged()</code></td>
									<td><code>()</code></td>
									<td>Checks if the current <code>value</code> differs from the last saved state value.</td>
								</tr>
								<tr>
									<td><code>reset()</code></td>
									<td><code>()</code></td>
									<td>Resets the file selector, restoring display parameters to the last saved value.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</section>

				<!-- HTML Attributes Section -->
				<section id="attributes" class="doc-section">
					<h2>HTML Attributes</h2>
					<div class="api-table-wrapper">
						<table class="api-table">
							<thead>
								<tr>
									<th>Attribute</th>
									<th>Values</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td><code>required</code></td>
									<td>N/A</td>
									<td>Marks the component as required.</td>
								</tr>
								<tr>
									<td><code>data-tabindex</code></td>
									<td><code>Number</code></td>
									<td>Sets the native tabindex on the final rendered input component.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</section>
			</main>
		</div>

		<!-- Footer -->
		<%-include('_footer.ejs')%>
	</div>

	<!-- Interactive page scripting -->
	<script type="module">
		window.addEventListener("load", async () => {
			// Initialize component
			const form = new $fgta5.Form('myform');
			const flb = form.Inputs.playground_filebox

			form.render()

			// UI state update elements
			const stateValue = document.getElementById('state_value');
			const stateFile = document.getElementById('state_file');
			const stateEditMode = document.getElementById('state_editmode');
			const stateLastValue = document.getElementById('state_lastvalue');
			const stateIsChanged = document.getElementById('state_ischanged');

			// Sync status displays
			const updateStats = () => {
				stateValue.innerText = JSON.stringify(flb.value);
				stateFile.innerText = typeof flb.file === 'object' ? `[File] Name: ${flb.file.name}, Size: ${flb.file.size}B` : "0";
				stateEditMode.innerText = flb.InEditMode ? "true" : "false";
				stateLastValue.innerText = JSON.stringify(flb.getLastValue());
				stateIsChanged.innerText = flb.isChanged() ? "true" : "false";
			};

			// Listen for events
			flb.Nodes.Input.addEventListener('change', updateStats);

			// Setup button control listeners
			document.getElementById('btn_toggle_edit').addEventListener('click', () => {
				form.lock(flb.InEditMode)
				updateStats();
			});

			let downloadLinkActive = false;
			document.getElementById('btn_set_link').addEventListener('click', () => {
				downloadLinkActive = !downloadLinkActive;
				if (downloadLinkActive) {
					flb.setDownloadLink("download_sample.pdf", "#");
				} else {
					flb.setDownloadLink(null);
				}
				updateStats();
			});

			document.getElementById('btn_commit').addEventListener('click', () => {
				form.acceptChanges()
				updateStats();
			});

			document.getElementById('btn_reset').addEventListener('click', () => {
				form.reset()
				updateStats();
			});

			// Initial Sync
			updateStats();
		});
	</script>
</body>

</html>
